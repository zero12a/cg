<insert id="insertUser" resultType="HashMap">
	<![CDATA[
insert into TEMP_USER (a,b) values(1,2)]]>
</insert>

<!--R:select-->
<select	id="selectUserOne" resultType="HashMap">
	<![CDATA[
select * from TEMP_USER
where a=2]]>
</select>
<select	id="selectUserList" resultType="HashMap">
	<![CDATA[
select * from TEMP_USER]]>
</select>

<!--U:update -->
<update	id="updateUser" resultType="HashMap">
	<![CDATA[
UPDATE TEMP SET A=1 WHERE B=2]]>
</update>

<!--D : delete-->
<delete	id="deleteUser" resultType="HashMap">
	<![CDATA[
DELETE FROM TEMP_USER  WHERE A=1]]>
</delete>
